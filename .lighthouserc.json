{
  "ci": {
    "collect": {
      "staticDistDir": "./out",
      "url": [
        "http://localhost/",
        "http://localhost/blog"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:seo": ["error", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
